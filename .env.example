# Clerk
# Safe to expose in the browser. Copy from Clerk Dashboard -> API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Server-only secret. Copy from Clerk Dashboard -> API Keys.
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Server-only webhook signing secret. Copy from Clerk Dashboard -> Webhooks -> your endpoint.
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Clerk route config used by the prebuilt auth pages in this app.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/generate
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/generate
# Base app URL used for metadata, redirects, and webhook testing.
# Production example: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Enable Google and GitHub social connections in the Clerk Dashboard.

# Database
# Neon example: postgres://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/rovara?sslmode=require
# Supabase example: postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres
DATABASE_URL=

# External APIs
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2400
OPENAI_TIMEOUT_MS=30000
NEXT_PUBLIC_MAPBOX_TOKEN=
OPENWEATHER_API_KEY=
GOOGLE_PLACES_API_KEY=
